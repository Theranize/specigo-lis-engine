# SpeciGo LIS Integration Engine - Environment Variables
# Copy this file to .env and fill in the values before running the engine.
# NEVER commit .env to version control. It contains database credentials.
#
# On the Windows Service installation at MMI, set these as Windows
# environment variables via System Properties -> Advanced -> Environment Variables
# rather than a .env file, so they persist across reboots without the file.

# ---------------------------------------------------------------------------
# Database - SpeciGo LIMS MySQL (u151751738_theranizeDevh1)
# ---------------------------------------------------------------------------

# MySQL host - use 127.0.0.1 if the LIMS DB is on the same machine,
# or the remote IP/hostname if the engine connects to a cloud DB.
DB_HOST=69.62.77.70

# MySQL port - default 3306
DB_PORT=3306

# MySQL credentials - use a dedicated read/write user for the integration engine.
# Do NOT use the root account.
DB_USER=u151751738_theranizeDevU
DB_PASSWORD=Aw&v7Ac9
DB_NAME=u151751738_theranizeDevh1

# Connection pool size - 5 is sufficient for a single-analyser deployment.
# Increase to 10 if multiple analysers share this engine instance.
DB_POOL_SIZE=5

# ---------------------------------------------------------------------------
# Analyser config
# ---------------------------------------------------------------------------

# Path to the analyser JSON config file.
# Relative paths are resolved from the project root (where index.js lives).
# Leave unset to use the default: config/analysers/au480_mmi.json
# CONFIG_FILE=config/analysers/au480_mmi.json

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Winston log level: error | warn | info | debug
# Use 'info' in production. Use 'debug' during site commissioning at MMI.
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# REST API (used by IntegrationAPI.js - Step 10)
# ---------------------------------------------------------------------------

# Port the Express REST API listens on.
# The React dashboard and LIMS backend proxy to this port.
API_PORT=3001
