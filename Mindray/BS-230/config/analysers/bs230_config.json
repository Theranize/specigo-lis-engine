{
  "_comment": "SpeciGo LIS Integration Engine - Analyser Instance Config (Mindray BS-230)",
  "_doc_version": "v1.0 - May 2026",
  "_site": "TBD - confirm at site commissioning",
  "_last_updated": "2026-05-05",
  "_confirmed_from": "BS-230 Operator's Manual V8.0 (2022-12), section 8.6 LIS setup",

  "lab_uid": "REPLACE_AT_SITE",
  "analyzer_uid": "REPLACE_AT_SITE",
  "manufacturer": "Mindray",
  "model": "BS-230",
  "model_family": "BS Series",
  "category": "Clinical Chemistry Analyser",
  "site": "TBD",
  "serial_number": "TBD",

  "connection": {
    "_comment": "BS-230 RS-232 defaults per manual section 8.6.2 Table 8.2: COM1, 9600/8/N/1, no flow control. Operator must set the analyzer-side host parameters to match.",
    "type": "serial",
    "port": "COM4",
    "baudRate": 9600,
    "dataBits": 8,
    "stopBits": 1,
    "parity": "none",
    "flowControl": "none",
    "rtscts"  : false,
    "xon"     : false,
    "xoff"    : false,
    "autoOpen": false
  },

  "protocol": {
    "_comment": "BS-230 supports both ASTM E1394 and HL7 per manual section 1.4.8/1.4.9. v1 of this engine implements ASTM E1394 (LIS2-A2) only - same wire format as the Beckman Access 2 driver. Set Protocol=ASTM 1394, Mode=Bidirectional or Unidirectional in the analyser's Host Communication Parameters window.",
    "standard": "ASTM E1394 / LIS2-A2",
    "enqByte": "0x05",
    "eotByte": "0x04",
    "stxByte": "0x02",
    "etxByte": "0x03",
    "etbByte": "0x17",
    "ackByte": "0x06",
    "nakByte": "0x15",
    "checksumEnabled": true,
    "fieldDelimiter": "|",
    "componentDelimiter": "^",
    "repeatDelimiter": "\\",
    "escapeCharacter": "&",
    "maxFrameBytes": 240
  },

  "lis_settings": {
    "_comment": "Mirror the values configured in the BS-230 Host Communication Parameters window (Utility > System Setup > Host F5). See manual section 8.6.2 Table 8.2.",
    "transportMode": "Serial",
    "protocol": "ASTM 1394",
    "mode": "Bidirectional",
    "timeoutSeconds": 30,
    "autoConnectOnStartup": true,
    "retryAfterDisconnection": true,
    "retryIntervalSeconds": 30,
    "sendCompleteSamples": true,
    "sendIncompleteSamples": false,
    "sendProgrammedSamples": false,
    "sendActualResultsAndRerunResults": true,
    "bypassResultsBeyondLinearityRange": false,
    "ignoreAlarmsForUnknownChemistries": true,
    "rerunFinishedChemistriesWhenDownloaded": false
  },

  "message_filters": {
    "_comment": "Process patient results only for Phase 1. QC/calibration enabled in future via this flag.",
    "patient_results": true,
    "qc_results": false,
    "calibration_results": false
  },

  "parameter_map": {
    "_comment": "Mindray BS-230 uses 'Channel No.' to identify each chemistry on the LIS host (manual section 8.6.3). The channel number is whatever the operator types into the Channel No. column on the analyzer side - it can be a numeric code (e.g. '1', '12') or an alphanumeric mnemonic. Whatever value you choose there must appear as the key here so the parser can look it up. The defaults below use the standard Mindray short-code mnemonics; replace with site-specific channel numbers if the analyzer is configured numerically.",

    "GLU":    { "code": "GLU",    "lims_name": "Glucose",                       "unit": "mg/dL"  },
    "UREA":   { "code": "UREA",   "lims_name": "Urea",                          "unit": "mg/dL"  },
    "BUN":    { "code": "BUN",    "lims_name": "Blood Urea Nitrogen",           "unit": "mg/dL"  },
    "CREA":   { "code": "CREA",   "lims_name": "Creatinine",                    "unit": "mg/dL"  },
    "URIC":   { "code": "URIC",   "lims_name": "Uric Acid",                     "unit": "mg/dL"  },
    "TP":     { "code": "TP",     "lims_name": "Total Protein",                 "unit": "g/dL"   },
    "ALB":    { "code": "ALB",    "lims_name": "Albumin",                       "unit": "g/dL"   },
    "GLO":    { "code": "GLO",    "lims_name": "Globulin",                      "unit": "g/dL"   },
    "TBIL":   { "code": "TBIL",   "lims_name": "Total Bilirubin",               "unit": "mg/dL"  },
    "DBIL":   { "code": "DBIL",   "lims_name": "Direct Bilirubin",              "unit": "mg/dL"  },
    "IBIL":   { "code": "IBIL",   "lims_name": "Indirect Bilirubin",            "unit": "mg/dL"  },
    "ALT":    { "code": "ALT",    "lims_name": "Alanine Aminotransferase",      "unit": "U/L"    },
    "AST":    { "code": "AST",    "lims_name": "Aspartate Aminotransferase",    "unit": "U/L"    },
    "ALP":    { "code": "ALP",    "lims_name": "Alkaline Phosphatase",          "unit": "U/L"    },
    "GGT":    { "code": "GGT",    "lims_name": "Gamma-Glutamyl Transferase",    "unit": "U/L"    },
    "LDH":    { "code": "LDH",    "lims_name": "Lactate Dehydrogenase",         "unit": "U/L"    },
    "CK":     { "code": "CK",     "lims_name": "Creatine Kinase",               "unit": "U/L"    },
    "CKMB":   { "code": "CKMB",   "lims_name": "Creatine Kinase - MB",          "unit": "U/L"    },
    "AMY":    { "code": "AMY",    "lims_name": "Amylase",                       "unit": "U/L"    },
    "LIPA":   { "code": "LIPA",   "lims_name": "Lipase",                        "unit": "U/L"    },
    "CHOL":   { "code": "CHOL",   "lims_name": "Total Cholesterol",             "unit": "mg/dL"  },
    "TG":     { "code": "TG",     "lims_name": "Triglycerides",                 "unit": "mg/dL"  },
    "HDL":    { "code": "HDL",    "lims_name": "HDL Cholesterol",               "unit": "mg/dL"  },
    "LDL":    { "code": "LDL",    "lims_name": "LDL Cholesterol",               "unit": "mg/dL"  },
    "VLDL":   { "code": "VLDL",   "lims_name": "VLDL Cholesterol",              "unit": "mg/dL"  },
    "CA":     { "code": "CA",     "lims_name": "Calcium",                       "unit": "mg/dL"  },
    "PHOS":   { "code": "PHOS",   "lims_name": "Phosphorus",                    "unit": "mg/dL"  },
    "MG":     { "code": "MG",     "lims_name": "Magnesium",                     "unit": "mg/dL"  },
    "FE":     { "code": "FE",     "lims_name": "Iron",                          "unit": "ug/dL"  },
    "TIBC":   { "code": "TIBC",   "lims_name": "Total Iron Binding Capacity",   "unit": "ug/dL"  },
    "UIBC":   { "code": "UIBC",   "lims_name": "Unsaturated Iron Binding Capacity", "unit": "ug/dL" },
    "NA":     { "code": "NA",     "lims_name": "Sodium",                        "unit": "mmol/L" },
    "K":      { "code": "K",      "lims_name": "Potassium",                     "unit": "mmol/L" },
    "CL":     { "code": "CL",     "lims_name": "Chloride",                      "unit": "mmol/L" },
    "HBA1C":  { "code": "HBA1C",  "lims_name": "Glycated Haemoglobin",          "unit": "%"      },
    "CRP":    { "code": "CRP",    "lims_name": "C-Reactive Protein",            "unit": "mg/L"   },
    "RF":     { "code": "RF",     "lims_name": "Rheumatoid Factor",             "unit": "IU/mL"  },
    "ASO":    { "code": "ASO",    "lims_name": "Anti-Streptolysin O",           "unit": "IU/mL"  },
    "MALB":   { "code": "MALB",   "lims_name": "Microalbumin",                  "unit": "mg/L"   }
  }
}
