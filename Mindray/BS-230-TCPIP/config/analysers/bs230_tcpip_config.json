  "_site": "TBD - confirm at site commissioning",
  "_last_updated": "2026-05-06",
  "_confirmed_from": "BS-230 Operator's Manual V8.0 (2022-12), section 8.6 LIS setup",

  "lab_uid": "REPLACE_AT_SITE",
  "analyzer_uid": "REPLACE_AT_SITE",
  "manufacturer": "Mindray",
  "model": "BS-230",
  "model_family": "BS Series",
  "category": "Clinical Chemistry Analyser",
  "site": "TBD",
  "serial_number": "TBD",

  "connection": {
    "_comment": "BS-230 in TCP/IP mode dials OUT to the LIS host on the configured port. The engine binds a TCP listener and accepts the analyser as the connecting peer. On the analyser side (Utility > System Setup > Host F5), set Transport=Network/TCP, Host IP = this workstation's LAN IP, and Host Port = the value below. 'host' here is the listen interface; use '0.0.0.0' to accept connections on all NICs, or pin to a specific IP for stricter binding.",
    "type": "tcp",
    "host": "0.0.0.0",
    "port": 7118,
    "keepAlive": true,
    "keepAliveInitialDelayMs": 30000
  },

  "protocol": {
    "_comment": "BS-230 supports both ASTM E1394 and HL7 per manual section 1.4.8/1.4.9. v1 of this engine implements ASTM E1394 (LIS2-A2) only — same wire format as the serial variant. Set Protocol=ASTM 1394, Mode=Bidirectional or Unidirectional in the analyser's Host Communication Parameters window.",
    "standard": "ASTM E1394 / LIS2-A2",
    "enqByte": "0x05",
    "eotByte": "0x04",
    "stxByte": "0x02",
    "etxByte": "0x03",
    "etbByte": "0x17",
    "ackByte": "0x06",
    "nakByte": "0x15",
    "checksumEnabled": true,
    "fieldDelimiter": "|",
    "componentDelimiter": "^",
    "repeatDelimiter": "\\",
    "escapeCharacter": "&",
    "maxFrameBytes": 240,
    "_unidirectional_comment": "Per BS-230 manual §8.6.2, 'Unidirectional' on the analyser only disables sample-program downloads from LIS — the ASTM E1394 transport-layer ACK/NAK handshake is unchanged in both modes and the analyser ENQ has a ~3s ACK timeout. This flag therefore ONLY relaxes the ENQ-precedes-STX rule (some firmware sends STX directly in true unidirectional mode); ACK/NAK is always sent. Safe to leave true even when the analyser is set to Bidirectional. Also auto-enabled if lis_settings.mode == 'Unidirectional'.",
    "unidirectional": true
  },

  "lis_settings": {
    "_comment": "Mirror the values configured in the BS-230 Host Communication Parameters window (Utility > System Setup > Host F5). See manual section 8.6.2 Table 8.2.",
    "transportMode": "Network",
    "protocol": "ASTM 1394",
    "mode": "Unidirectional",
    "timeoutSeconds": 30,
    "autoConnectOnStartup": true,
    "retryAfterDisconnection": true,
    "retryIntervalSeconds": 30,
    "sendCompleteSamples": true,
    "sendIncompleteSamples": false,
    "sendProgrammedSamples": false,
    "sendActualResultsAndRerunResults": true,
    "bypassResultsBeyondLinearityRange": false,
    "ignoreAlarmsForUnknownChemistries": true,
    "rerunFinishedChemistriesWhenDownloaded": false
  },

  "message_filters": {
    "_comment": "Process patient results only for Phase 1. QC/calibration enabled in future via this flag.",
    "patient_results": true,
    "qc_results": false,
    "calibration_results": false
  },

